# Portfolio Prism Environment Variables
# =====================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# =============================================================================
# CLOUDFLARE WORKER SECRETS
# =============================================================================
# These are set via `wrangler secret put <NAME>` in infrastructure/cloudflare/
# They are NOT read from this file - this is documentation only.

# Finnhub API Key (for stock data)
# Get one at: https://finnhub.io/register
# FINNHUB_API_KEY=your_finnhub_api_key_here

# GitHub Token (for crash report / feedback issues)
# Create at: https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo (for public)
# GITHUB_TOKEN=ghp_your_github_token_here

# GitHub Repository (where feedback issues are created)
# Format: owner/repo
# GITHUB_REPO=your-username/portfolio-prism

# =============================================================================
# SUPABASE (Hive Community Features)
# =============================================================================
# Get these from your Supabase project dashboard: Settings > API

# Supabase Project URL
# SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous Key (safe to expose in client)
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role Key (NEVER expose in client - server-side only)
# SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# CLOUDFLARE WORKER URL
# =============================================================================
# Single source of truth for both frontend and backend.
# Default: https://portfolio-prism-proxy.bold-unit-582c.workers.dev
# WORKER_URL=https://your-worker.workers.dev

# =============================================================================
# LOCAL DEVELOPMENT (Optional)
# =============================================================================

# Trade Republic credentials (for development/testing only)
# These are stored securely in system keyring at runtime
# TR_PHONE_NUMBER=+49123456789
# TR_PIN=1234

# Override data directory (default: ~/Library/Application Support/PortfolioPrism)
# PRISM_DATA_DIR=/path/to/custom/data/dir

# =============================================================================
# ECHO BRIDGE (Development HTTP Transport)
# =============================================================================
# The Echo Bridge provides an HTTP API for development without building
# the full Tauri app. It enables hot-reload workflows and REST-like debugging.
#
# SECURITY: Set strong random tokens when using Echo Bridge in any shared
# environment (e.g., team development servers, CI pipelines).
# The default token is only suitable for local single-user development.

# Frontend token (Vite/TypeScript side)
# Used by src/lib/ipc.ts when running in browser mode
# VITE_ECHO_BRIDGE_TOKEN=your-strong-random-token-here

# Backend token (Python engine side)
# Used by src-tauri/python/portfolio_src/headless/transports/echo_bridge.py
# PRISM_ECHO_TOKEN=your-strong-random-token-here
#
# NOTE: Both tokens must match for authentication to succeed.
